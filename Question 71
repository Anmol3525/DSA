#include <stdio.h>
#include <string.h>

#define MAX 100

int main() {
    int m, q;
    scanf("%d", &m);   // size of hash table
    scanf("%d", &q);   // number of operations

    int table[MAX];

    // Initialize table with -1 (empty)
    for (int i = 0; i < m; i++) {
        table[i] = -1;
    }

    while (q--) {
        char op[10];
        scanf("%s", op);

        if (strcmp(op, "INSERT") == 0) {
            int key;
            scanf("%d", &key);

            int h = key % m;
            int i = 0;

            while (i < m) {
                int index = (h + i*i) % m;

                if (table[index] == -1) {
                    table[index] = key;
                    break;
                }
                i++;
            }
        }

        else if (strcmp(op, "SEARCH") == 0) {
            int key;
            scanf("%d", &key);

            int h = key % m;
            int i = 0;
            int found = 0;

            while (i < m) {
                int index = (h + i*i) % m;

                if (table[index] == key) {
                    found = 1;
                    break;
                }

                if (table[index] == -1) {
                    break;
                }

                i++;
            }

            if (found)
                printf("FOUND\n");
            else
                printf("NOT FOUND\n");
        }
    }

    return 0;
}
