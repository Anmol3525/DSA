#include <stdio.h>

int queue[100];
int front = 0, rear = -1;

void enqueue(int x)
{
    rear++;
    queue[rear] = x;
}

void display()
{
    for(int i = front; i <= rear; i++)
        printf("%d ", queue[i]);
}

int main()
{
    int n;

    scanf("%d", &n);

    for(int i = 0; i < n; i++)
    {
        int x;
        scanf("%d", &x);
        enqueue(x);
    }

    display();

    return 0;
}
